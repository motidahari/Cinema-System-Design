# =============================================================================
# Cinema Reservation System — Environment Variables
# Copy to .env and fill in values before running locally.
# =============================================================================

# ── identity-service (port 3001) ──────────────────────────────────────────────
PORT=3001
NODE_ENV=local

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=cinema_user
DB_PASSWORD=cinema_pass
DB_NAME=cinema_db

JWT_SECRET=change-me-to-a-32-char-minimum-secret-value
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

LOGIN_LOCK_THRESHOLD=5
LOGIN_LOCK_WINDOW_MIN=15

CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# OTEL_EXPORTER_OTLP_ENDPOINT=   # optional — OpenTelemetry collector

# ── cinema-service (port 3002) ────────────────────────────────────────────────
# PORT=3002
# IDENTITY_SERVICE_URL=http://localhost:3001
# SOCKET_CORS_ORIGINS=http://localhost:5173,http://localhost:4173
# RESERVATION_HOLD_MINS=15
# IDEMPOTENCY_TTL_HOURS=24
# REDIS_URL=                      # optional — only for horizontal scaling

# ── frontend (cinema-app) ─────────────────────────────────────────────────────
# VITE_API_BASE_URL=http://localhost
# VITE_SOCKET_URL=http://localhost
