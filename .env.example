# =============================================================================
# Cinema Reservation System — Environment Variables
# Copy to .env and fill in values before running.
# Usage: cp .env.example .env  then edit JWT_SECRET
# =============================================================================

# ── Common ────────────────────────────────────────────────────────────────────
NODE_ENV=local
DB_USERNAME=cinema_user
DB_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD
DB_NAME=cinema_db

JWT_SECRET=change-me-to-a-32-char-minimum-secret!!
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

LOGIN_LOCK_THRESHOLD=5
LOGIN_LOCK_WINDOW_MIN=15

CORS_ORIGINS=http://localhost,http://localhost:5173
SOCKET_CORS_ORIGINS=http://localhost,http://localhost:5173

RESERVATION_HOLD_MINS=15
IDEMPOTENCY_TTL_HOURS=24

# REDIS_URL=                      # OPTIONAL — only for horizontal scaling (ADR-10)
# OTEL_EXPORTER_OTLP_ENDPOINT=    # OPTIONAL — OpenTelemetry export (ADR-13)

# ── Local dev (non-Docker) — uncomment when running services directly ─────────
# DB_HOST=localhost
# DB_PORT=5432
# PORT=3001                       # identity-service
# PORT=3002                       # cinema-service
# IDENTITY_SERVICE_URL=http://localhost:3001

# ── Frontend (Vite dev server only — Docker uses same-origin /api/v1) ─────────
# VITE_IDENTITY_API_URL=http://localhost:3001/api/v1
# VITE_CINEMA_API_URL=http://localhost:3002/api/v1
# VITE_SOCKET_URL=http://localhost:3002
