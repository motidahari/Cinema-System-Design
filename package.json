{
    "name": "cinema-reservation-system",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "backend-services/identity-service",
        "backend-services/cinema-service",
        "backend-services/libs/core/sdk",
        "backend-services/libs/core/shared",
        "frontend-application/cinema-app"
    ],
    "scripts": {
        "prepare": "husky",
        "lint": "eslint . --ext .ts,.tsx --no-error-on-unmatched-pattern",
        "lint:fix": "eslint . --ext .ts,.tsx --fix --no-error-on-unmatched-pattern",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "npm run typecheck --workspaces --if-present",
        "test": "npm run test --workspaces --if-present",
        "build": "npm run build --workspaces --if-present",
        "dev": "bash scripts/dev.sh",
        "dev:stop": "bash scripts/dev.sh --stop",
        "dev:logs": "bash scripts/dev.sh --logs"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.5.0",
        "@commitlint/config-conventional": "^19.5.0",
        "@typescript-eslint/eslint-plugin": "^7.18.0",
        "@typescript-eslint/parser": "^7.18.0",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-react": "^7.37.2",
        "eslint-plugin-react-hooks": "^4.6.2",
        "husky": "^9.1.7",
        "lint-staged": "^15.2.10",
        "nodemon": "^3.1.14",
        "prettier": "^3.4.2",
        "typescript": "^5.4.5"
    },
    "engines": {
        "node": ">=20.0.0",
        "npm": ">=10.0.0"
    },
    "overrides": {
        "vitest": "3.2.6",
        "@vitest/coverage-v8": "3.2.6"
    }
}
