{
    "name": "@cinema/identity-service",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "start": "node dist/main",
        "start:dev": "ts-node -r tsconfig-paths/register src/main.ts",
        "test:unit": "jest --config jest.config.js --selectProjects unit",
        "test:integration": "jest --config jest.config.js --selectProjects integration --runInBand",
        "test:api": "jest --config jest.config.js --selectProjects api --runInBand --passWithNoTests",
        "test:cov": "jest --config jest.config.js --coverage --passWithNoTests"
    },
    "dependencies": {
        "@cinema/internal-sdk": "*",
        "@cinema/shared": "*",
        "@nestjs/common": "^11.1.27",
        "@nestjs/config": "^4.0.4",
        "@nestjs/core": "^11.1.27",
        "@nestjs/jwt": "^10.2.0",
        "@nestjs/passport": "^10.0.3",
        "@nestjs/platform-express": "^11.1.27",
        "@nestjs/platform-socket.io": "11.1.27",
        "@nestjs/terminus": "^11.1.1",
        "@nestjs/throttler": "^6.4.0",
        "@nestjs/typeorm": "^11.0.2",
        "@nestjs/websockets": "11.1.27",
        "bcrypt": "^5.1.1",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "cookie-parser": "^1.4.7",
        "helmet": "^8.0.0",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "pg": "^8.13.1",
        "prom-client": "^15.1.3",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "typeorm": "^0.3.20",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@nestjs/testing": "^11.1.27",
        "@types/bcrypt": "^5.0.2",
        "@types/cookie-parser": "^1.4.8",
        "@types/jest": "^29.5.14",
        "@types/node": "^22.0.0",
        "@types/passport-jwt": "^4.0.1",
        "@types/supertest": "^7.2.0",
        "jest": "^29.7.0",
        "supertest": "^7.2.2",
        "ts-jest": "^29.1.2",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.4.5"
    }
}
