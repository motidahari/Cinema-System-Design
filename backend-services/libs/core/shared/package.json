{
    "name": "@cinema/shared",
    "version": "1.0.0",
    "private": true,
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "test:unit": "jest"
    },
    "jest": {
        "preset": "ts-jest",
        "testEnvironment": "node",
        "testMatch": [
            "<rootDir>/tests/**/*.spec.ts"
        ],
        "transform": {
            "^.+\\.tsx?$": [
                "ts-jest",
                {
                    "tsconfig": {
                        "rootDir": ".",
                        "composite": false,
                        "types": [
                            "node",
                            "jest"
                        ]
                    }
                }
            ]
        }
    },
    "peerDependencies": {
        "typeorm": "^0.3.0"
    },
    "devDependencies": {
        "@types/jest": "^29.5.14",
        "@types/node": "^22.0.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.2",
        "typescript": "^5.4.5"
    }
}
